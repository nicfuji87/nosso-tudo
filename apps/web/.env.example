# ============================================================
# Nosso Tudo — variáveis de ambiente (copie para .env.local)
# Nunca commitar segredos (SR-063). Chaves separadas por ambiente.
# ============================================================

# Supabase (projeto: ecwcqooogsvsrddwjavh)
NEXT_PUBLIC_SUPABASE_URL=https://ecwcqooogsvsrddwjavh.supabase.co
# Project Settings → API → anon/public key (é pública por design — protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings → API → service_role (SEGREDO — somente servidor)
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app (usada em redirects de auth/e-mail)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Integrações ----
# Asaas e WhatsApp/uazapi são configurados na ÁREA ADMIN (tabela integration_settings),
# não aqui. Edge Functions leem esses segredos via service_role.
# Demais (futuras):
# ANTHROPIC_API_KEY=
# RESEND_API_KEY=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
